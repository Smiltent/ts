<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ts.hackclub.com</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <link rel="stylesheet" href="/public/css/style.css">
    <link rel="stylesheet" href="/public/css/whiteboard.css">
    <link rel="stylesheet" href="/public/css/toolbar.css">

    <link rel="shortcut icon" href="/public/favicon.ico" type="image/x-icon">
</head>
<body>
    <% if (user) { %>
        <div id="tsAuth">
            <span class="tsAuthEmail"><%= user.email %></span>
            <span>|</span>
            <a href="/auth/logout">
                logout
            </a>
        </div>
    <% } %>

    <% if (isAdmin) { %>
        <button id="tsSaveButton">save</button>
    <% } %>

    <div id="tsViewport">
        <div id="tsWorld">
            <div id="tsCanvasBg"></div>
            <svg id="tsCanvas" width="10000" height="10000"></svg>
        </div>
    </div>

    <div id="tsToolbar">
        <div class="tsToolGroup">
            <button id="tsBtnMove" class="tsToolBtn" title="Move">
                <i class="fa-solid fa-up-down-left-right fa-xl"></i>
            </button>
            <button id="tsBtnMarker" class="tsToolBtn" title="Draw">
                <i class="fa-solid fa-marker fa-xl"></i>
            </button>
            <button id="tsBtnPencil" class="tsToolBtn" title="Draw">
                <i class="fa-solid fa-pencil fa-xl"></i>
            </button>
            <button id="tsBtnErase" class="tsToolBtn" title="Erase">
                <i class="fa-solid fa-eraser fa-xl"></i>
            </button>
        </div>

        <div class="tsToolGroup tsBrushGroup">
            <!-- the fact that -40 works very well in this situation, insane! -->
            <input type="range" id="tsBrushSizeSlider" min="-40" max="40" value="3" class="tsBrushSlider"> 
            <span id="tsBrushSizeLabel" class="tsBrushLabel">3</span>
        </div>

        <div class="tsToolGroup tsColorGroup">
            <button id="tsBtnColorBlack" class="tsColorBtn" title="Black">
                <span class="tsColorSwitch" style="background-color: #000000;"></span>
            </button>
            <button id="tsBtnColorBlue" class="tsColorBtn" title="Black">
                <span class="tsColorSwitch" style="background-color: #0f39c5;"></span>
            </button>
            <button id="tsBtnColorPicker" class="tsColorBtn tsColorPickerBtn" title="Custom">
                <i class="fa-solid fa-droplet "></i>
                <input type="color" id="tsColorPickerInput" value="#000000" tabindex="-1" aria-hidden="true">
            </button>
        </div>
    </div>

    <script src="/public/js/paint.js"></script>
    <script>replayOps(<%- JSON.stringify(drawing.ops) %>)</script>
</body>
</html>